label_encoder = LabelEncoder()
labels_encoded = label_encoder.fit_transform(df['label'])


def segment_signal(data, labels, window_size=100, step_size=20):
    segments, seg_labels = [], []
    for i in range(0, len(data) - window_size + 1, step_size):
        window = data[i:i + window_size]
        label = labels[i + window_size - 1]
        segments.append(window)
        seg_labels.append(label)
    return np.array(segments), np.array(seg_labels)


X, y = segment_signal(features_scaled, labels_encoded, 100, 20)


# ==========================================
# FIXED TRAIN-VAL-TEST SPLIT (IMPORTANT)
# ==========================================
X_train, X_test, y_train, y_test = train_test_split(
