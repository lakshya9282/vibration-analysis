def parse_classification_report(report_string):
    metrics = {}

    accuracy_match = re.search(r'accuracy\s+([0-9.]+)', report_string)
    if accuracy_match:
        metrics['accuracy'] = float(accuracy_match.group(1))

    macro_match = re.search(r'macro avg\s+([0-9.]+)\s+([0-9.]+)\s+([0-9.]+)', report_string)
    if macro_match:
        metrics['macro_avg_f1'] = float(macro_match.group(3))

    weighted_match = re.search(r'weighted avg\s+([0-9.]+)\s+([0-9.]+)\s+([0-9.]+)', report_string)
    if weighted_match:
        metrics['weighted_avg_f1'] = float(weighted_match.group(3))

    return metrics


